    function demirbas_detay($id = null)
    {
        $this->sec('demirbas_detay');

        if(!is_numeric($id)){ die(); }

        #Demirbas detay
        $x = $this->sql->from('demirbas_listesi')->where("id = $id")->get();
        $data['q'] = $x;

        #Log detay
        $log = @$this->sql->select('kullanici_id,islem,tarih')->from('_log')->where("tablo = 'demirbas_listesi' AND data_id = " . $id)->orderBy('log_id DESC')->limit(1)->get();
        $data['log'] = $log;
        $data['logGoster'] = false;

        if($this->sql->count() > 0){

            #Import edilen verilerde sorun cikmamasi icin kullanici bilgisi kontrol ediliyor.
            if(is_numeric($log->kullanici_id)){
                $user = @$this->sql->from('_kullanici')->where('ID = ' . $log->kullanici_id)->get();
                $data['user'] = $user->adsoyad;
                $data['logGoster'] = true;
            }
        }


        load::view('modal/demirbas_detay', $data);
    }

