    function rapor_olustur(){

        if( $_SESSION['csrf'] != $_POST['token']){
            echo "0";
            die();
        }

        $parameters = array();

        $buluntu_yili_ilk = @$_POST['buluntu_yili_ilk'];
        $buluntu_yili_son = @$_POST['buluntu_yili_son'];
        $buluntu_yeri = implode(',',$_POST['bk_buluntuyeri_id']);
        $uretim_yeri = implode(',', $_POST['bk_uretimyeri_id']);
        $buluntu_tip = implode(',',$_POST['bk_tip_id']);
        $donem = implode(',',$_POST['bk_donem_id']);
        $formobje = implode(',', $_POST['bk_formobje_id']);
        $yapim_malzemesi = implode(',',$_POST['bk_yapim_mlz_id']);

        $grafik_tipi = @$_POST['grafik_tipi'];

        $grafik_tipi = $grafik_tipi . @$_POST['grafik_mod'];


        if(isset($buluntu_yeri)) $parameters[1] = 'bk.bk_buluntuyeri_id IN(' . $buluntu_yeri . ')';
        if(isset($uretim_yeri)) $parameters[2] = 'bk.bk_uretimyeri_id IN(' . $uretim_yeri . ')';
        if(isset($buluntu_tip)) $parameters[3] = 'bk.bk_tip_id IN(' . $buluntu_tip . ')';
        if(isset($donem)) $parameters[4] = 'bk.bk_donem_id IN(' . $donem . ')';
        if(isset($yapim_malzemesi)) $parameters[5] = 'bk.bk_yapim_mlz_id IN(' . $yapim_malzemesi . ')';
        if(isset($buluntu_yili_ilk) && $buluntu_yili_ilk != '') $parameters[6] = 'SUBSTRING(bk.buluntu_tarihi,-4,4) >= ' . $buluntu_yili_ilk;
        if(isset($buluntu_yili_son) && $buluntu_yili_son != '') $parameters[7] = 'SUBSTRING(bk.buluntu_tarihi,-4,4) <= ' . $buluntu_yili_son;
        if(isset($formobje)) $parameters[8] = 'bk.bk_formobje_id IN(' . $formobje . ')';

        $where = implode(' AND ', $parameters);
        $where = '  WHERE ' . $where . " AND SUBSTRING(bk.buluntu_tarihi,-4,4) != ''";
        if(count($parameters) < 1) {$where = '';}


        $query = 'SELECT lb.list_adi as buluntu_yeri, SUBSTRING(bk.buluntu_tarihi,-4,4) as buluntu_yili, count(*) as adet from buluntu_karti as bk LEFT JOIN list_data as lb ON lb.list_id = bk.bk_buluntuyeri_id' . $where . ' group by bk.bk_buluntuyeri_id, SUBSTRING(bk.buluntu_tarihi,-4,4)';
        $buluntu = $this->sql->query($query, true, false);

        $results = array();

        $div = '';
        $chart = '';

        foreach($buluntu as $b){
            $results[$b->buluntu_yeri][$b->buluntu_yili] = $b->adet;
        }

        $toplamBuluntu = count($results);

        $setcol = '12';
        $setheight = '600px';

        if($toplamBuluntu > 1) {
            $setcol = '6';
            $setheight = '400px';
        }

        $s = 0;

        if($buluntu_yili_son == '')
            $buluntu_yili_son = date('Y');

        if($buluntu_yili_ilk != '') {
            $buluntu_yili_ilk = $buluntu_yili_ilk.'-';
        }else{
            $buluntu_yili_son = '';
        }

        $yilBilgisi = $buluntu_yili_ilk.$buluntu_yili_son;

        foreach($results as $key => $value){

            $data = array();
            $totalCount = 0;

            $x = 0;
            foreach($value as $a => $b){

                $data[$x]['label'] = (string)$a;
                $data[$x]['value'] =  $b;

                $totalCount = $totalCount + intval($b);
                $x++;
            }

            if($totalCount > 0){

                $s++;

                $div .= '<div class="col-md-'.$setcol.'" style="box-sizing: border-box;margin-top: 15px;"><div id="line_'.$s.'" style="border: 1px dotted #ddd;"></div></div>';

                $chart .= 'FusionCharts.ready(function() {var myChart'.$s.' = new FusionCharts({type: "'.$grafik_tipi.'", renderAt: "line_'.$s.'", width: "100%", height: "'.$setheight.'", dataFormat: "json",';
                $chart .= 'dataSource: {"chart": {"caption": "'.$key.' '.$yilBilgisi.' <br><br>","subcaption": "Toplam Buluntu: '.$totalCount.'","plottooltext": "$label yılına ait toplam <b>$value</b> buluntu mevcut", "showlegend": "1", "showpercentvalues": "0", "numbersuffix": " adet", "legendposition": "bottom", "theme": "fusion"},';

                $chart .= '"data": ' . json_encode($data);
                $chart .= '}';
                $chart .= '}).render();});';
            }

        }

        echo $div . '<script type="text/javascript">'. $chart . '</script>';
    }


