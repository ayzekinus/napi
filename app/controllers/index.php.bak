    function konservasyon_get(){
        $this->sec('buluntu_ekle');

        $id  = strip_tags(addslashes($_POST['id']));

        if(!is_numeric($id))
            die("0");

        @$this->sql->from('konservasyon_listesi')->where('kons_bk_id = ' . $id)->get();
        if($this->sql->count() > 0){
            # daha once olusturulmus rapor var - popup ac
            echo "1";
        }else{
            //$d = $this->sql->select('b.bk_id, LPAD(b.buluntu_no,4,0) as buluntu_no, l.list_adi as yapim_malzemesi, l.form as form_yapim, ll.list_adi as form_obje, ll.form as form_sikke, x.list_adi as buluntu_yeri')->from('buluntu_karti as b')->leftJoin('list_data as x','x.list_id = b.bk_buluntuyeri_id')->leftJoin('list_data as l','l.list_id = b.bk_yapim_mlz_id')->leftJoin('list_data as ll','ll.list_id = b.bk_formobje_id')->where('b.bk_id = ' . $id)->get();
            $d = $this->sql->select('b.bk_id, LPAD(b.buluntu_no,4,0) as buluntu_no, l.list_adi as yapim_malzemesi, l.form as form_yapim, ll.list_adi as form_obje, ll.form as form_sikke')->from('buluntu_karti as b')->leftJoin('list_data as l','l.list_id = b.bk_yapim_mlz_id')->leftJoin('list_data as ll','ll.list_id = b.bk_formobje_id')->where('b.bk_id = ' . $id)->get();
            if($this->sql->count() < 1)
                die("0");

            $tip = array('Metal','Taş','Kemik','Cam','Seramik');

            if(in_array($d->form_yapim, $tip, true) || $d->form_sikke == 'Sikke') {
                # konservasyon olusturma formuna yonlendir
                $tip = $d->form_yapim;

                if($d->form_sikke == 'Sikke')
                    $tip = $d->form_sikke;

                echo strtolower(str_replace('ş', 's',$tip));
            }else{
                # konservasyon olusturmaya uygun degil
                echo "0";
            }
        }
    }

    function konservasyon_duzenle($id = null){
        $this->sec('buluntu_duzenle');

        if(!is_numeric($id))
            die("0");

        $this->konservasyon_islem($id, 1, null);
    }

    function konservasyon_islem($id = null, $islem = 0, $tip = null){
        $this->sec('buluntu_ekle');
        load::helper('csrf_generate');

        if(!is_numeric($id))
            die("0");

        $d = $this->sql->select('b.bk_id, LPAD(b.buluntu_no,4,0) as buluntu_no, a.anakod, l.list_adi as yapim_malzemesi, l.form as form_yapim, ll.list_adi as form_obje, ll.form as form_sikke, x.list_adi as buluntu_yeri')->from('buluntu_karti as b')->leftJoin('anakod as a','a.anakod_id = b.bk_anakod_id')->leftJoin('list_data as x','x.list_id = b.bk_buluntuyeri_id')->leftJoin('list_data as l','l.list_id = b.bk_yapim_mlz_id')->leftJoin('list_data as ll','ll.list_id = b.bk_formobje_id')->where('b.bk_id = ' . $id)->get();

        $data['form_tip'] = $tip;

        if($islem == 1){
            $q = $this->sql->from('konservasyon_listesi')->where('kons_bk_id = ' . $id)->get();
            $data['q'] = $q;
            if(is_null($tip))
                $data['form_tip'] = $q->tip;
        }

        $data['id'] = $id;
        $data['qq'] = $d;
        $data['token'] = csrf_generate();
        $data['islem'] = $islem;


        load::view('modal/konservasyon_islem', $data);
    }

    function konservasyon_detay($id = null, $print = 0){

        $this->sec('buluntu_listesi');

        if(!is_numeric($id))
            die("0");

        $d = $this->sql->select('b.bk_id, LPAD(b.buluntu_no,4,0) as buluntu_no, a.anakod, l.list_adi as yapim_malzemesi, l.form as form_yapim, ll.list_adi as form_obje, ll.form as form_sikke, x.list_adi as buluntu_yeri')->from('buluntu_karti as b')->leftJoin('anakod as a','a.anakod_id = b.bk_anakod_id')->leftJoin('list_data as x','x.list_id = b.bk_buluntuyeri_id')->leftJoin('list_data as l','l.list_id = b.bk_yapim_mlz_id')->leftJoin('list_data as ll','ll.list_id = b.bk_formobje_id')->where('b.bk_id = ' . $id)->get();
        $q = $this->sql->from('konservasyon_listesi')->where('kons_bk_id = ' . $id)->get();

        $data['q'] = $q;
        $data['qq'] = $d;
        $data['form_tip'] = $q->tip;

        if(!$print){

            $log = @$this->sql->select('kullanici_id,islem,tarih')->from('_log')->where("tablo = 'konservasyon_listesi' AND data_id = " . $id)->orderBy('log_id DESC')->limit(1)->get();
            $data['log'] = $log;
            $data['logGoster'] = false;

            if($this->sql->count() > 0){

                #Import edilen verilerde sorun cikmamasi icin kullanici bilgisi kontrol ediliyor.
                if(is_numeric($log->kullanici_id)){
                    $user = @$this->sql->from('_kullanici')->where('ID = ' . $log->kullanici_id)->get();
                    $data['user'] = $user->adsoyad;
                    $data['logGoster'] = true;
                }
            }
            load::view('modal/konservasyon_detay', $data);
        }else{

            load::helper('string');

            load::view('modal/konservasyon_print', $data);
        }

    }

