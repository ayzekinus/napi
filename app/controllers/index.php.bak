        load::view('ajax/evrak_listesi', $data);
    }

    function evrak_listesi_data($tip = 'gelen')
    {
        $this->sec('evrak_listesi_data');

        if($tip !== 'gelen' && $tip !== 'giden' && $tip !== 'favori')
            die();

        $tip = strtolower($tip);
        $where = "evrak_tipi = '".$tip."'";
        if($tip == 'favori')
            $where = "favori = 1";


        $this->datatables = load::library('datatable');
        $this->datatables->select('id, evrak_konusu, evrak_kurum, evrak_sayi, evrak_no, evrak_tarihi, kayit_tarihi, evrak_oncelik, evrak_tipi')
            ->from('evrak_yonetimi')->where($where)->orderBy('id DESC');

        $this->datatables->edit_column('id', '$1', 'id')
            ->edit_column('evrak_konusu', '$1', 'evrak_konusu')
            ->edit_column('evrak_kurum', '$1', 'evrak_kurum')
            ->edit_column('evrak_sayi', '$1', 'evrak_sayi')
            ->edit_column('evrak_no', '$1', 'evrak_no')
            ->edit_column('evrak_tarihi', '$1', 'evrak_tarihi')
            ->edit_column('kayit_tarihi', '$1', 'kayit_tarihi')
            ->edit_column('evrak_oncelik', '$1', 'evrak_oncelik')
            ->edit_column('evrak_tipi', '$1', 'evrak_tipi');

        echo $this->datatables->generate();
    }

    function evrak_detay($id = null)
    {
        $this->sec('evrak_detay');

        if(!is_numeric($id)){ die(); }

        #Evrak detay
        $x = $this->sql->from('evrak_yonetimi')->where("id = $id")->get();
        $data['q'] = $x;

        $data['dosyalar'] = @$this->sql->from('evrak_yonetimi_dosya')->where('evrak_id = ' . $id)->orderBy('id DESC')->getAll();

        #Log detay
        $log = @$this->sql->select('kullanici_id,islem,tarih')->from('_log')->where("tablo = 'evrak_yonetimi' AND data_id = " . $id)->orderBy('log_id DESC')->limit(1)->get();
        $data['log'] = $log;
        $data['logGoster'] = false;

        if($this->sql->count() > 0){

            #Import edilen verilerde sorun cikmamasi icin kullanici bilgisi kontrol ediliyor.
            if(is_numeric($log->kullanici_id)){
                $user = @$this->sql->from('_kullanici')->where('ID = ' . $log->kullanici_id)->get();
                $data['user'] = $user->adsoyad;
                $data['logGoster'] = true;
            }
        }

        load::view('modal/evrak_detay', $data);
    }

    function evrak_getir($id = null, $islem = 0, $tip = 'gelen'){

        $this->sec('evrak_detay');

        if(!is_numeric($id)){ die(); }

        $tip = strtolower($tip);

        $where = "id > $id AND evrak_tipi = '".$tip."'";
        $order = "id ASC";

        # onceki kayit butonuna basildiysa
        if($islem == 0){
            $where = "id < $id AND evrak_tipi = '".$tip."'";
            $order = "id DESC";
        }

        $x = $this->sql->select('id, kayit_tarihi')->from('evrak_yonetimi')->where($where)->orderBy($order)->limit(1)->get();

        if($this->sql->count() > 0){

            echo $this->evrak_detay($x->id);
