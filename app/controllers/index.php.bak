            ->edit_column('a.durum', '$1', 'a.durum');

        echo $this->datatables->cache(0)->generate();
    }

    function anakod_detay($id = null, $print = 0)
    {
        $this->sec('anakod_detay');

        if(!is_numeric($id)){ die(); }

        #Anakod detay
        $x = $this->sql->from('anakod')->where("anakod_id = $id")->get();
        $data['q'] = $x;

        #Buluntu Yeri bilgisi
        $by = @$this->sql->from('list_data')->where('list_id = ' . $x->anakod_buluntuyeri_id)->get();
        $data['by'] = $by->list_adi;

        #Buluntu sayisi
        $count = @$this->sql->query('SELECT count(*) as adet from buluntu_karti where bk_anakod_id = ' . $id,false,false);
        $data['count'] = $count->adet;

        if($print == 0){
            #Log detay
            $log = @$this->sql->select('kullanici_id,islem,tarih')->from('_log')->where("tablo = 'anakod' AND data_id = " . $id)->orderBy('log_id DESC')->limit(1)->get();
            $data['log'] = $log;
            $data['logGoster'] = false;

            if($this->sql->count() > 0){

                #Import edilen verilerde sorun cikmamasi icin kullanici bilgisi kontrol ediliyor.
                if(is_numeric($log->kullanici_id)){
                    $user = @$this->sql->from('_kullanici')->where('ID = ' . $log->kullanici_id)->get();
                    $data['user'] = $user->adsoyad;
                    $data['logGoster'] = true;
                }
            }

            $ilk = $id - 9;
            if($ilk < 0) {
                $ilk = 1;
            }

            if($id <= 10){
                $son = $id + (17-$id);
            }else{
                $son = $id + 7;
            }

            #Kendisinden onceki ve sonraki 9 kayit (kendisi dahil)
            $ilkGetir = $this->sql->select('anakod_id, anakod')->from('anakod')->where("anakod_id BETWEEN $ilk AND $son")->getAll();

            $ilkData = '';
            foreach($ilkGetir as $ilk){
                if($id == $ilk->anakod_id){
                    $sec = ' class="active"';
                }else{$sec = '';}
                $ilkData .= '<li '.$sec.'><a href="#" data-id="'.$ilk->anakod_id.'">'.$ilk->anakod.'</a></li>';
            }

            $data['anakodPage'] = $ilkData;

            load::view('modal/anakod_detay', $data);

        }else{
            load::view('modal/anakod_print', $data);
        }
    }


    /* BULUNTU */

    function buluntu_ekle($id = null)
    {
        $this->sec('buluntu_ekle');

        if (is_numeric($id)){
            $x = $this->sql->from('anakod')->where("anakod_id = $id")->get();
            $data['q'] = $x;
            $data['id'] = $id;

            $min = $id - 5;
            $max = $id + 5;

            $anakod_where = "anakod_id BETWEEN $min AND $max";
            $anakod_data =$this->sql->select('anakod_id, anakod')->from('anakod')->where($anakod_where)->orderBy('anakod_id DESC')->limit(10)->getAll();

            $data['lb_buluntu_yeri'] = $this->acilir_liste_getir(1, true, @$x->anakod_buluntuyeri_id);

        }else{
            $anakod_data =$this->sql->select('anakod_id, anakod')->from('anakod')->orderBy('anakod_id DESC')->limit(10)->getAll();
        }

        load::helper('csrf_generate');

        $data['token'] = csrf_generate();
        $data['anakod'] = $anakod_data;

        load::view('modal/buluntu_ekle', $data);
    }

    function buluntu_duzenle($id = null)
    {
        $this->sec('buluntu_duzenle');

        if(!is_numeric($id)){ die(); }

        load::helper('csrf_generate');

        $data['token'] = csrf_generate();

        $x = $this->sql->from('buluntu_karti')->where("bk_id = $id")->get();
        $data['q'] = $x;

        $data['galeri'] = $this->sql->from('buluntu_galeri')->where('bk_id = '. $id)->getAll();
        $data['anakod'] = $this->sql->select('anakod_id, anakod')->from('anakod')->where("anakod_id = $x->bk_anakod_id")->orderBy('anakod ASC')->get();

        $data['lb_buluntu_yeri'] = $this->sql->from('list_data')->where("list_id = $x->bk_buluntuyeri_id")->get();
        $data['lb_formobje'] = $this->sql->from('list_data')->where("list_id = $x->bk_formobje_id")->get();
        $data['lb_yapimmalzemesi'] = $this->sql->from('list_data')->where("list_id = $x->bk_yapim_mlz_id")->get();
        $data['lb_uretimyeri'] = $this->sql->from('list_data')->where("list_id = $x->bk_uretimyeri_id")->get();
        $data['lb_donem'] = $this->sql->from('list_data')->where("list_id = $x->bk_donem_id")->get();
        $data['lb_tip'] = $this->sql->from('list_data')->where("list_id = $x->bk_tip_id")->get();
        $data['lb_renk_hamur'] = $this->sql->from('list_data')->where("list_id = $x->bk_hamur_renk_id")->get();
        $data['lb_renk_astar'] = $this->sql->from('list_data')->where("list_id = $x->bk_astar_renk_id")->get();


        load::view('modal/buluntu_duzenle', $data);
    }

