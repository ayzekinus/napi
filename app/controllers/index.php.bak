    function acma_rapor_listesi_data()
    {

        $this->sec('acma_rapor_listesi_data');
        $this->datatables = load::library('datatable');

        $this->datatables->select('ar.ID, ar.baslik,  bye.list_adi, ar.calisma_yili, ar.yazim_tarihi, ar.adsoyad, ar.rapor_tipi, ar.durum')
            ->from('acma_rapor as ar')
            ->leftJoin('list_data as bye', 'ar.buluntuyeri_id = bye.list_id')->orderBy('ar.ID DESC');

        $this->datatables->edit_column('ar.ID', '$1', 'ar.ID')
