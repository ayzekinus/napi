    function acma_rapor_detay($id = null, $print = 0)
    {
        $this->sec('acma_rapor_detay');

        if(!is_numeric($id)){ die(); }

        #Buluntu detay
        $x = $this->sql->from('acma_rapor')->where("ID = $id")->get();
        $data['q'] = $x;

        #Buluntu Yeri bilgisi
        $d = @$this->sql->from('list_data')->where('list_id = ' . $x->buluntuyeri_id)->get();
        $data['by'] = $d->list_adi;


        if($print == 0){
            #Log detay
            $log = @$this->sql->select('kullanici_id,islem,tarih')->from('_log')->where("tablo = 'acma_rapor' AND data_id = " . $id)->orderBy('log_id DESC')->limit(1)->get();
            $data['log'] = $log;
            $data['logGoster'] = false;

            if($this->sql->count() > 0){

                #Import edilen verilerde sorun cikmamasi icin kullanici bilgisi kontrol ediliyor.
                if(is_numeric($log->kullanici_id)){
                    $user = @$this->sql->from('_kullanici')->where('ID = ' . $log->kullanici_id)->get();
                    $data['user'] = $user->adsoyad;
                    $data['logGoster'] = true;
                }
            }

            load::view('modal/acma_rapor_detay', $data);
        }else{
            load::view('modal/acma_rapor_print', $data);
        }
    }

    function acma_rapor_getir($id = null, $islem = 0){

        $this->sec('acma_rapor_detay');

        if(!is_numeric($id)){ die(); }

        $where = "ID > $id";
        $order = "ID ASC";

        #onceki kayit butonuna basildiysa
        if($islem == 0){
            $where = "ID < $id";
            $order = "ID DESC";
        }

        $x = $this->sql->select('ID, baslik')->from('acma_rapor')->where($where)->orderBy($order)->limit(1)->get();

        if($this->sql->count() > 0){

            echo $this->acma_rapor_detay($x->ID, 0);
        }else{
            #herhangi bir veri donmezse sayfaya bir sey basma..
            echo "0";
        }

    }

    function acma_rapor_galeri($id = 0){
        if(!is_numeric($id)){ die(); }

        $where = 'acma_rapor_id = ' . $id . ' AND kim = ' . $_SESSION['ID'];
        if($id > 0)
            $where = 'acma_rapor_id = ' . $id;

        $data['galeri'] =  $this->sql->from('acma_rapor_galeri')->where($where)->orderBy('resim_id DESC')->getAll();
        load::view('modal/acma_rapor_galeri',$data);
    }


