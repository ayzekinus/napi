    function anasayfa()
    {

        //$cache = load::library('cache');
        //$cache->start(12);

        $x = @$this->sql->query('select count(*) as adet from anakod', false,false);
        $data['anakod_toplam'] = $x->adet;

        $x = @$this->sql->query('select count(*) as adet from buluntu_karti', false,false);
        $data['buluntu_toplam'] = $x->adet;

        $x = @$this->sql->query('select count(*) as adet from acma_rapor', false,false);
        $data['acmarapor_toplam'] = $x->adet;

        $x = @$this->sql->query('select count(*) as adet from evrak_yonetimi', false,false);
        $data['evrak_toplam'] = $x->adet;

        $x = @$this->sql->query('select count(*) as adet from demirbas_listesi', false,false);
        $data['demirbas_toplam'] = $x->adet;

        $x = @$this->sql->query('select count(*) as adet from _kullanici', false,false);
        $data['kullanici_toplam'] = $x->adet;


        $loglar = $this->sql->select('data_title, data_cat, islem_tip, adsoyad,  tarih, islem')->from('islem_gecmisi')->where("data_title != ''")->orderBy('log_id DESC')->limit(15)->getAll();
        $d = '';
        foreach($loglar as $log){

            $c = 'color: #4B8230;';
            if($log->islem == 2)
                $c = 'color: #99783B';

            $d .= '<tr style="'.$c.'"><td>'.$log->data_title.'</td><td><span class="row_kayit_tipi">'.$log->data_cat.'</span></td><td>'.$log->islem_tip.'</td><td>'.$log->adsoyad.'</td><td>'.$log->tarih.'</td></tr>';
        }

        $data['loglar'] = $d;

        $data['kullanici_log'] = $this->sql->from('_kullanici_log as l')->leftJoin('_kullanici as k','k._kullanici = l.user')->where('l.hata = 0')->limit(15)->orderBy('l.ID DESC')->getAll();
        $data['kullanici_log_hata'] = $this->sql->from('_kullanici_log as l')->where('l.hata = 1')->limit(15)->orderBy('l.ID DESC')->getAll();


        load::view('ajax/anasayfa', $data);
        //$cache->finish();
    }

