        $this->datatables->select('a.anakod_id,  a.anakod, l.list_adi, a.buluntu_yili, a.plankare, a.tabaka, a.seviye, a.mezarno, a.durum')
            ->from('anakod as a')
            ->leftJoin('list_data as l', 'a.anakod_buluntuyeri_id = l.list_id')->orderBy('a.anakod_id DESC');

        $this->datatables->edit_column('a.anakod_id', '$1', 'a.anakod_id')
