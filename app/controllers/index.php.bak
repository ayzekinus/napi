    /* AJAX */

    function select_data($which = ''){

        #Form alaninda kullanilan select elemanlarinin icerigini dinamik hale getirir.

        load::helper("escape_str");

        $term = escape_str(htmlspecialchars(strip_tags(addslashes(trim($_GET['q'])))));
        $sql = '';

        switch($which){
            case 'anakod': $tip = 0; $sql = "SELECT anakod,anakod_id from anakod where anakod LIKE '$term%'"; break;
            case 'buluntu': $tip = 1; break;
            case 'formobje': $tip = 2; break;
            case 'yapim_malzemesi': $tip = 3; break;
            case 'uretim_yeri': $tip = 5; break;
            case 'donem'; $tip = 6; break;
            case 'tip': $tip = 4; break;
            case 'renk': $tip = 7; break;
            case 'yayin_kategorisi': $tip = 8; break;
            default: die(); break;
        }

        # Islem tipi anakod degil ve parametre doluysa
        $where = "";
        if($term != '' && $tip != 0){
            $where = " AND list_adi LIKE '%$term%' ";
        }

        # Islem tipi anakod degilse
        if($tip != 0)
            $sql = "SELECT list_id, list_adi from list_data where tip = $tip $where ORDER BY list_adi ASC";

        # Eger parametre bos ise veri getirme (anakod)
        if($tip == 0 && empty($term))
            die();

        $query = $this->sql->query($sql);
        $data = array();

        foreach ($query as $q) {
            if($tip == 0)
                array_push($data, array("id" => $q->anakod_id, "text" => stripslashes($q->anakod)));
            else
                array_push($data, array("id" => $q->list_id, "text" => stripslashes($q->list_adi)));
        }

        $results = array("results" => $data);

        echo json_encode($results);
    }

    function acilir_liste_getir($tur = null, $ret = false, $id = 0){

        # buluntu fonksiyonunda kullaniliyor, select icin..

        $listeler = $this->sql->query("SELECT list_id, list_adi from list_data where durum = 1 AND tip = $tur order by list_id ASC", true, false);
        $x = '<option value=""></option>';

        $sec = '';
        foreach ($listeler as $s) {
            if($id != 0 && $s->list_id == $id){$sec = ' selected';}else{$sec = '';}
            $x.= '<option value="'.$s->list_id.'" '.$sec.'>'.stripslashes($s->list_adi).'</option>';
        }

        if(!$ret){
            echo $x;
        }else{
            return $x;
        }

    }

    function log_getir($id = null, $tablo = 'anakod'){

        # Detay sayfasindaki islem loglarini getirir, yetkili degilse sadece 5 kayit gosterir.

        if(!is_numeric($id)){die();}

        $tablo = addslashes(strip_tags($tablo));
        $limit = 'limit 5';

        if($_SESSION['yetki'] == 'S') $limit = '';

        $data = $this->sql->query("SELECT l.log_id, l.tarih, k.adsoyad, l.islem from _log as l LEFT JOIN _kullanici as k ON l.kullanici_id = k.ID where l.data_id = " . $id . " AND l.tablo = '".$tablo."' order by log_id DESC $limit",true,false);

        $datax = '';
        foreach ($data as $item) {

            $islem = '';
            if($item->islem == 1){
                $islem = ' <th style="font-weight: normal;color: #4B8230;">Oluşturuldu</th>';
            }else{
                $islem = ' <th style="font-weight: normal;color: #99783B;">Güncellendi</th>';
            }

            $datax .= '<tr>
                            <th style="font-weight: normal;">'.$item->log_id.'</th>
                            <th style="font-weight: normal;">'.$item->tarih.'</th>
                            <th style="font-weight: normal;font-style: italic;">'.$item->adsoyad.'</th>
                            '.$islem.'
                       </tr>';
        }

        echo  '<tr><th width="40px">ID</th><th>Tarih</th><th width="150px">Kullanıcı</th><th width="100px">İşlem</th></tr>' . $datax;

    }


