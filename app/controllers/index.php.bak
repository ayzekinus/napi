    function buluntu_listesi_galeri()
    {
        $this->sec('buluntu_listesi');



        /*
         *
         *

        select `bg`.`bk_id` AS `bk_id`,`a`.`anakod` AS `anakod`,`bye`.`list_adi` AS `buluntu_yeri`,lpad(`bk`.`buluntu_no`,4,0) AS `buluntu_no`,`fo`.`list_adi` AS `formobje`,`bk`.`buluntu_tarihi` AS `buluntu_tarihi`,`bg`.`dosya` AS `dosya`,  bk.bk_buluntuyeri_id, bk.bk_formobje_id, bk.bk_yapim_mlz_id from ((((`buluntu_galeri` `bg` join `buluntu_karti` `bk` on((`bk`.`bk_id` = `bg`.`bk_id`))) join `list_data` `bye` on((`bye`.`list_id` = `bk`.`bk_buluntuyeri_id`))) join `anakod` `a` on((`a`.`anakod_id` = `bk`.`bk_anakod_id`))) join `list_data` `fo` on((`fo`.`list_id` = `bk`.`bk_formobje_id`))) group by `bg`.`bk_id` order by `bg`.`bk_id` desc

         *
         * */


        //@$this->sql->from('buluntu_galeri_view')->getAll();
        //$data['toplam_adet'] = $this->sql->count();
        $data['galeri'] = $this->sql->from('buluntu_galeri_view')->limit(25)->getAll();

        $data['yillar'] = $this->sql->query('SELECT DISTINCT buluntu_yili FROM rp_yillara_gore_buluntu order by buluntu_yili', true,false);


        load::view('ajax/buluntu_listesi_galeri', $data);
    }


    function buluntu_listesi_galeri_data(){
        //$this->sec('buluntu_listesi');

        $parameters = array();


        $buluntu_yeri = implode(',',$_POST['buluntu_yeri']);
        $formobje = implode(',', $_POST['form_obje']);
        $yapim_malzemesi = implode(',',$_POST['yapim_malzemesi']);
        $buluntu_yili = implode(',',$_POST['buluntu_yili']);


        if(isset($buluntu_yeri)) $parameters[0] = 'bk_buluntuyeri_id IN(' . $buluntu_yeri . ')';
        if(isset($yapim_malzemesi)) $parameters[1] = 'bk_yapim_mlz_id IN(' . $yapim_malzemesi . ')';
        if(isset($buluntu_yili) && $buluntu_yili != '') $parameters[2] = 'SUBSTRING(buluntu_tarihi,-4,4) IN( ' . $buluntu_yili . ')';
        if(isset($formobje)) $parameters[3] = 'bk_formobje_id IN(' . $formobje . ')';


        $where = implode(' AND ', $parameters);
        $where = '  WHERE ' . $where . " AND SUBSTRING(buluntu_tarihi,-4,4) != ''";

        if(count($parameters) < 1) {$where = '';}

        $query = 'SELECT * from buluntu_galeri_view' . $where . ' LIMIT 25';
        $galeri = $this->sql->query($query, true, false);


        $veri = '';

        foreach($galeri as $g){
            $veri .= '<img src="'.Url::base('uploads/images/thumb/'.$g->dosya).'" data-tooltip="<b>Anakod: </b> '.$g->anakod.' <br/> <b>Buluntu No: </b> '.$g->buluntu_no.' <br/><b>Buluntu Yeri: </b>'. $g->buluntu_yeri.' <br/> <b>Buluntu Tarihi: </b> '. $g->buluntu_tarihi.'<br/><b>Form/Obje: </b> '.$g->formobje.'">';
        }


        $random = time();
        $div = '<style type="text/css">.galeri_icerik_'.$random.'{width: 100%; margin: 0px; padding: 0px; overflow: hidden !important; background: #EDEDED; border-top: 1px solid #DDDDDD; }</style><div class="galeri_icerik_'.$random.'">';
        $js = '<script type="text/javascript">$(\'.galeri_icerik_'.$random.' img\').css("border", "1px dashed #ADA9A9");$(".galeri_icerik_'.$random.' img").hover(function(){$(this).css("border", "1px solid #ADA9A9").addClass("aktif");$(".galeri_icerik_'.$random.' img").not("aktif").addClass("pasif");}, function(){$(this).css("border", "1px dashed #ADA9A9").removeClass("aktif");$(".galeri_icerik_'.$random.' img").removeClass("pasif");});';
        $js .= '$(\'.galeri_icerik_'.$random.'\').BalancedGallery({autoResize: false, background: null, idealHeight: 200, idealWidth: null, maintainOrder: true, orientation: \'horizontal\',padding: 20, shuffleUnorderedPartitions: true, viewportHeight: null, viewportWidth: null});</script>';


        echo $div. $veri . '</div>' . $js;

    }


    function buluntu_galeri($id = 0){
        if(!is_numeric($id)){ die(); }

        $where = 'bk_id = ' . $id . ' AND kim = ' . $_SESSION['ID'];
        if($id > 0)
            $where = 'bk_id = ' . $id;


        $data['galeri'] =  $this->sql->from('buluntu_galeri')->where($where)->orderBy('id DESC')->getAll();
        load::view('modal/buluntu_galeri',$data);
    }

    function buluntu_detay($id = null, $print = 0)
    {
        $this->sec('buluntu_detay');

        if(!is_numeric($id)){ die(); }

        #Buluntu detay
        $x = $this->sql->select('*, LPAD(buluntu_no,4,0) as buluntu_num')->from('buluntu_karti')->where("bk_id = $id")->get();
        $data['q'] = $x;

        #Anakod
        $y = $this->sql->from('anakod')->where("anakod_id = $x->bk_anakod_id")->get();
        $data['anakod'] = $y->anakod;

        #Buluntu Yeri bilgisi
        $d = @$this->sql->from('list_data')->where('list_id = ' . $x->bk_buluntuyeri_id)->get();
        $data['by'] = $d->list_adi;

        #Formobje bilgisi
        $d = @$this->sql->from('list_data')->where('list_id = ' . $x->bk_formobje_id)->get();
        $data['formobje'] = $d->list_adi;

        #Yapim Malzemesi bilgisi
        $d = @$this->sql->from('list_data')->where('list_id = ' . $x->bk_yapim_mlz_id)->get();
        $data['yapim_malzemesi'] = $d->list_adi;

        #Uretim Yeri bilgisi
        $d = @$this->sql->from('list_data')->where('list_id = ' . $x->bk_uretimyeri_id)->get();
        $data['uretimyeri'] = $d->list_adi;

        #Donem bilgisi
        $d = @$this->sql->from('list_data')->where('list_id = ' . $x->bk_donem_id)->get();
        $data['donem'] = $d->list_adi;

        #Tip bilgisi
        $d = @$this->sql->from('list_data')->where('list_id = ' . $x->bk_tip_id)->get();
        $data['tip'] = $d->list_adi;

        #Hamur Rengi bilgisi
        $d = @$this->sql->from('list_data')->where('list_id = ' . $x->bk_hamur_renk_id)->get();
        $data['hamur_rengi'] = $d->list_adi;

        #Astar Rengi bilgisi
        $d = @$this->sql->from('list_data')->where('list_id = ' . $x->bk_astar_renk_id)->get();
        $data['astar_rengi'] = $d->list_adi;

        #Buluntu Gorselleri
        $data['galeri'] = @$this->sql->from('buluntu_galeri')->where("bk_id = $id")->getAll();


        if($print == 0){
            #Log detay
            $log = @$this->sql->select('kullanici_id,islem,tarih')->from('_log')->where("tablo = 'buluntu_karti' AND data_id = " . $id)->orderBy('log_id DESC')->limit(1)->get();
            $data['log'] = $log;
            $data['logGoster'] = false;

            if($this->sql->count() > 0){

                #Import edilen verilerde sorun cikmamasi icin kullanici bilgisi kontrol ediliyor.
                if(is_numeric($log->kullanici_id)){
                    $user = @$this->sql->from('_kullanici')->where('ID = ' . $log->kullanici_id)->get();
                    $data['user'] = $user->adsoyad;
                    $data['logGoster'] = true;
                }
            }


            /* Tab menu sayfalama */

            $ilk = $x->buluntu_no - 7;
            if($ilk < 0) {
                $ilk = 1;
            }

            if($x->buluntu_no < 8){
                $son = $x->buluntu_no + (14-$x->buluntu_no);
            }else{
                $son = $x->buluntu_no + 7;
            }

            #Kendisinden onceki ve sonraki 7 kayit (kendisi dahil) toplam 15
            $ilkGetir = $this->sql->select('bk_id, LPAD(buluntu_no,4,0) as buluntu_num')->from('buluntu_karti')->where("bk_anakod_id = $x->bk_anakod_id AND buluntu_no BETWEEN $ilk AND $son")->getAll();

            $ilkData = '';
            foreach($ilkGetir as $ilk){
                if($id == $ilk->bk_id){
                    $sec = ' class="active"';
                }else{$sec = '';}
                $ilkData .= '<li '.$sec.'><a href="#" data-id="'.$ilk->bk_id.'">'.$ilk->buluntu_num.'</a></li>';
            }

            $data['anakodPage'] = $ilkData;

            load::view('modal/buluntu_detay', $data);
        }else{
            load::view('modal/buluntu_print', $data);
        }
    }

    function buluntu_anakod_getir($id = null, $islem = 0){

        $this->sec('buluntu_detay');

        if(!is_numeric($id)){ die(); }

        $where = "bk_anakod_id > $id";
        $order = "bk_anakod_id ASC";

        #onceki kayit butonuna basildiysa
        if($islem == 0){
            $where = "bk_anakod_id < $id";
            $order = "bk_anakod_id DESC";
        }

        $x = $this->sql->select('bk_id, bk_anakod_id')->from('buluntu_karti')->where($where)->orderBy($order)->limit(1)->get();

        if($this->sql->count() > 0){

            #Sistemde kayitli son buluntuyu getirmek icin gerekli sorgu
            $y = $this->sql->select('bk_id')->from('buluntu_karti')->where("bk_anakod_id = $x->bk_anakod_id")->orderBy('bk_id DESC')->limit(1)->get();

            echo $this->buluntu_detay($y->bk_id, 0);
        }else{
            #herhangi bir veri donmezse sayfaya bir sey basma..
            echo "0";
        }

    }

